---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — page not found" description="This page doesn't exist (yet).">
  <!-- Easter egg: a single dramatic red slash scribes across ~1.5s in. -->
  <div class="samurai-slash" aria-hidden="true"></div>

  <section class="container notfound">
    <pre class="ascii mono" aria-hidden="true">
{`> ls /not-here
zsh: no such file or directory: /not-here`}
    </pre>
    <h1>404.</h1>
    <p class="lede prose">
      This page either never existed or wandered off. Either way — try
      <a href="/">heading home</a> or browsing <a href="/projects">the projects</a>.
    </p>
  </section>
</BaseLayout>

<style>
  .notfound { padding-block: var(--space-24); max-width: var(--prose-w); }
  .ascii {
    color: var(--ink-mute);
    background: transparent;
    border: 0;
    padding: 0;
    margin-bottom: var(--space-8);
    font-size: 0.85rem;
  }
  .lede { font-size: 1.1rem; }

  /* Samurai slash — a thin red diagonal line drawn left→up-right, then fades.
     transform-origin:left so width-growth reads as a "scribe", not an expand. */
  .samurai-slash {
    position: fixed;
    top: 55%;
    left: -25vw;
    width: 0;
    height: 3px;
    transform: rotate(-35deg);
    transform-origin: left center;
    background: linear-gradient(
      90deg,
      transparent,
      var(--accent),
      #ffffff,
      var(--accent),
      transparent
    );
    box-shadow: 0 0 14px rgba(255, 80, 80, 0.85);
    opacity: 0;
    pointer-events: none;
    z-index: 60;
    animation: samurai-slash 1.2s ease-out 1.5s forwards;
  }
  @keyframes samurai-slash {
    0%   { width: 0;     opacity: 1; }
    25%  { width: 150vw; opacity: 1; } /* ~300ms fast scribe */
    33%  { width: 150vw; opacity: 1; } /* brief hold */
    100% { width: 150vw; opacity: 0; } /* ~800ms fade */
  }

  @media (prefers-reduced-motion: reduce) {
    .samurai-slash { display: none; }
  }
</style>
